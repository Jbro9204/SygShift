# Safe browser configuration. Never place a Supabase secret or service-role key here.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Local/server-only setup values. Put real values in .env.local or your Cloudflare
# secret store, never in committed browser-delivered files.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-publishable-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SYGSHIFT_BOOTSTRAP_USERNAME=jbrown
SYGSHIFT_BOOTSTRAP_PASSWORD=temporary-password-not-for-git
SYGSHIFT_BOOTSTRAP_FIRST_NAME=Jordan
SYGSHIFT_BOOTSTRAP_LAST_NAME=Brown
